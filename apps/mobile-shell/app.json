{
  "expo": {
    "name": "Comma",
    "slug": "comma",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "comma",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#1a1814",
          "enableFullScreenImage_legacy": true
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.comma.app",
      "buildNumber": "2",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.comma"
    },
    "extra": {
      "webUrl": "https://comma-front-web.vercel.app/",
      "eas": {
        "projectId": "6769c796-0c29-40a4-8afb-24f4e6df08de"
      }
    }
  }
}
