{
  "name": "@comma/design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./theme.css": {
      "types": "./src/theme.css.ts",
      "default": "./src/theme.css.ts"
    },
    "./components.css": {
      "types": "./src/components.css.ts",
      "default": "./src/components.css.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.21.0",
    "@vanilla-extract/recipes": "^0.5.7"
  }
