{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["VITE_REDIRECT_URI", "VITE_REST_API_KEY"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"],
      "env": ["EXPO_PUBLIC_WEB_URL", "VITE_BASE_URL", "VITE_REST_API_KEY", "VITE_REDIRECT_URI"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
